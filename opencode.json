{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "del *": "ask",
      "Remove-Item *": "ask",
      "format *": "ask",
      "mkfs *": "ask",
      "dd *": "ask",
      "shutdown *": "ask",
      "restart *": "ask"
    }
  }
}
